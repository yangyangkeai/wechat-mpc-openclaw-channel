{
  "name": "@tingyang/openclaw-wechat-mpc",
  "version": "2026.3.274",
  "description": "Third-party platform-based OpenClaw WeChat Official Account (微信公众号) channel plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest --run"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wechat-mpc",
      "label": "WeChatMP-ThirdParty",
      "selectionLabel": "WeChat MP (Third-party Platform)",
      "docsPath": "/channels/wechat-mpc",
      "docsLabel": "wechat-mpc",
      "blurb": "Third-party platform-based OpenClaw WeChat Official Account (微信公众号) channel plugin.",
      "aliases": [
        "wechat-mpc",
        "微信公众号插件"
      ]
    },
    "install": {
      "npmSpec": "@tingyang/openclaw-wechat-mpc",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "keywords": [
    "openclaw",
    "wechat-mpc",
    "微信公众号插件"
  ],
  "author": "Tingyang Zhang",
  "license": "MIT",
  "devDependencies": {
    "openclaw": "^2026.3.24",
    "typescript": "^6.0.2"
  }
}
