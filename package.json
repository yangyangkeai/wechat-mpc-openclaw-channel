{
  "name": "@tingyang/openclaw-wechat-mpc",
  "version": "2026.4.18",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangyangkeai/wechat-mpc-openclaw-channel.git"
  },
  "description": "Third-party platform-based OpenClaw WeChat Official Account (微信公众号) channel plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc && openclaw gateway",
    "build": "tsc && node ./scripts/strip-console.mjs",
    "build_dev": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest --run"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wechat-mpc",
      "label": "WeChatMP-ThirdParty",
      "selectionLabel": "WeChat MP (Third-party Platform)",
      "docsPath": "/channels/wechat-mpc",
      "docsLabel": "wechat-mpc",
      "blurb": "Third-party platform-based OpenClaw WeChat Official Account (微信公众号) channel plugin.",
      "aliases": [
        "wechat-mpc",
        "wecom-kf",
        "微信公众号插件",
        "微信客服插件"
      ]
    },
    "install": {
      "npmSpec": "@tingyang/openclaw-wechat-mpc",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "keywords": [
    "openclaw",
    "wechat-mpc",
    "wecom-kf",
    "微信公众号插件",
    "微信客服插件"
  ],
  "author": "Tingyang Zhang",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "openclaw": "^2026.4.25",
    "typescript": "^6.0.2"
  }
}
